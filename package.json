{
  "name": "lumin-studio",
  "version": "0.0.0",
  "private": true,
  "description": "Lumin Studio — made-to-order 3D-printed lamps & decor (monorepo).",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:file": "eslint --cache --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify": "pnpm -s lint && pnpm -s typecheck && pnpm -s test && pnpm -s format:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
