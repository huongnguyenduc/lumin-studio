# Lumin Studio — infra compose env (Phase 0 skeleton).
# Copy → .env và điền. .env thật bị gitignore; prod nạp từ SOPS+age lúc deploy
# (conventions.md §Secrets / ADR-024). Sinh secret: openssl rand -hex 32
#
# Các giá trị để TRỐNG là BẮT BUỘC: compose dùng ${VAR:?...} nên `up` sẽ dừng ngay
# nếu chưa điền (không có default yếu nào lọt xuống prod).

# --- Postgres (app DB) ---
POSTGRES_USER=lumin
# BẮT BUỘC điền (để trống = compose dừng; không default — tránh ship mật khẩu yếu)
POSTGRES_PASSWORD=
POSTGRES_DB=lumin
POSTGRES_PORT=5432

# --- NATS ---
NATS_PORT=4222

# --- Garage (S3) — secret: openssl rand -hex 32 ---
GARAGE_RPC_SECRET=
GARAGE_ADMIN_TOKEN=
GARAGE_METRICS_TOKEN=
GARAGE_S3_PORT=3900
GARAGE_ADMIN_PORT=3903

# --- Core API payment-proof uploads (P2-c) ---
# S3 key này nên chỉ scoped vào bucket PAYMENT_PROOF_BUCKET. Không dùng GARAGE_ADMIN_TOKEN.
PAYMENT_PROOF_S3_ENDPOINT=http://127.0.0.1:3900
PAYMENT_PROOF_S3_REGION=garage
PAYMENT_PROOF_BUCKET=lumin-payment-proofs
PAYMENT_PROOF_PUBLIC_BASE_URL=http://127.0.0.1:3900/lumin-payment-proofs
PAYMENT_PROOF_ACCESS_KEY_ID=
PAYMENT_PROOF_SECRET_ACCESS_KEY=
PAYMENT_PROOF_KEY_PREFIX=payment-proofs
PAYMENT_PROOF_POST_TTL=5m
PAYMENT_PROOF_MAX_BYTES=10485760
# Retention (ADR-035): core-api sweeper xoá ảnh biên lai ~90 ngày SAU khi đơn vào terminal
# (PDPL data-minimization); 2160h = 90 ngày. Bucket lifecycle rule lo orphan (upload không thành đơn).
PAYMENT_PROOF_RETENTION=2160h
PAYMENT_PROOF_SWEEP_INTERVAL=6h

# --- Caddy ---
CADDY_HTTP_PORT=8080

# --- Cloudflare named tunnel (profile: edge) ---
# Token từ dashboard Cloudflare. Ingress (hostname → http://caddy:80) cấu hình ở dashboard.
TUNNEL_TOKEN=
