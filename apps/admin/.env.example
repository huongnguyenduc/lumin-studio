# Base URL of core-api. Read server-side only by the dashboard fetch (src/lib/dashboard-fetch.ts),
# which forwards the httpOnly `lumin_session` cookie to GET /admin/dashboard. NOT a NEXT_PUBLIC_
# var on purpose — it must stay out of the client bundle. In local dev core-api listens on :8080
# (config default PORT=8080); in compose/prod Caddy reverse-proxies to core-api:8080.
CORE_API_URL=http://localhost:8080
