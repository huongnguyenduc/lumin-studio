# Base URL of core-api. SERVER-ONLY — NOT a NEXT_PUBLIC_ var, so it never enters the client bundle.
# The storefront fetches the catalog server-side (src/lib/catalog.ts). In compose this is the internal
# service URL (e.g. http://core-api:8080); thrown-not-defaulted if unset.
CORE_API_URL=http://localhost:8080

# Shared secret guarding POST /api/revalidate — the on-write catalog cache purge (revalidateTag).
# Generate a long, high-entropy value. The future core-api product-change webhook must present it as
# the `x-revalidate-secret` header. Unset ⇒ the endpoint is CLOSED (500), never an open purge.
REVALIDATE_SECRET=change-me-to-a-long-random-string

# Public origin of the storefront — scheme + host, NO trailing slash (e.g. https://luminstudio.vn).
# SERVER-ONLY (never a NEXT_PUBLIC_ var). Feeds canonical links, the sitemap, robots.txt and Open Graph
# absolute image URLs (src/lib/site.ts). Thrown-not-defaulted if unset (a silent localhost base would
# de-index the site) — REQUIRED for every page render + `next build`. MUST include the scheme.
SITE_URL=http://localhost:3000
